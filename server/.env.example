# ============================================
# WhatsApp Cloud API Configuration
# ============================================

# Get these from https://developers.facebook.com
# Meta for Developers > Your App > WhatsApp > API Setup

# Your WhatsApp Business Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Permanent or temporary access token from Meta Developer Console
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# The business phone number to receive orders (with country code, no +)
BUSINESS_PHONE_NUMBER=919003028001

# ============================================
# Server Configuration
# ============================================

PORT=3001
NODE_ENV=development

# Frontend origin for CORS (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# ============================================
# Rate Limiting
# ============================================

# Max requests per IP per window
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=900000
